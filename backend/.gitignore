# ============================================================
# .gitignore — EduNet Backend
# ============================================================

# Node dependencies — never commit node_modules
node_modules/

# Environment secrets — NEVER commit any .env variants
.env
.env.local
.env.production
.env.development
.env.save
.env.save.*
.envo
*.env.bak
*.env.backup

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Build artifacts
dist/
build/
