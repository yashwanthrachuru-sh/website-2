# ============================================================
# EduNet Backend — Environment Variables
# ============================================================
# IMPORTANT: Never commit this file to version control (Git).
# Add .env to your .gitignore file.
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD="MyRoot@2026#Strong1"
DB_NAME=edunet

# --- JWT Authentication ---
# Generate a strong random secret for production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=edunet_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- CORS ---
# The origin allowed to access this API (your frontend URL)
FRONTEND_ORIGIN=http://localhost:5000
