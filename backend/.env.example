# ============================================================
# EduNet Backend Environment Variables — Example / Template
# ============================================================
# Copy this file to .env for local development.
# For production (Render), configure these in the Render dashboard — NOT here.
# ============================================================

# ── 1. Server Configuration ─────────────────────────────────
PORT=5000
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins.
# Production (Render dashboard): FRONTEND_ORIGIN=https://edunet-seven.vercel.app
# Local dev: include localhost as well
FRONTEND_ORIGIN=https://edunet-seven.vercel.app,http://localhost:5000,http://localhost:5500

# ── 2. Database Configuration (Use DATABASE_URL or individual params) ────
# Production: Use DATABASE_URL from Railway (set in Render dashboard):
# DATABASE_URL=mysql://username:password@host:port/database

# Local development only — individual parameters:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_password_here
DB_NAME=edunet

# ── 3. Authentication Secrets ────────────────────────────────
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=super_secret_session_key_here_replace_in_production
JWT_EXPIRES_IN=7d

# ── 4. Third-Party Integrations ─────────────────────────────
# OpenAI API Key (Optional — smart offline fallback works without it)
OPENAI_API_KEY=sk-placeholder_key_here

# ── 5. Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150
