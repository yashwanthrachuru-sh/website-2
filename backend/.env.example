# ============================================================
# EduNet Backend Environment Variables Example
# Copy this file to .env and configure details for production/dev
# ============================================================

# ── 1. Server Configuration ─────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_ORIGIN=https://edunet-frontend.vercel.app,http://localhost:5500

# ── 2. Database Configuration (Use DATABASE_URL or individual params) ────
# Railway DATABASE_URL string format:
# DATABASE_URL=mysql://username:password@host:port/database

# Individual Database Parameters:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=MyRoot@2026#Strong1
DB_NAME=edunet

# ── 3. Authentication Secrets ────────────────────────────────
JWT_SECRET=super_secret_session_key_here
JWT_EXPIRES_IN=7d

# ── 4. Third-Party Integrations ─────────────────────────────
# OpenAI API Key (Optional. Standard offline blueprints fallback if not provided)
OPENAI_API_KEY=sk-placeholder_key_here

# ── 5. Rate Limiting Limits ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150
