      "heading": "Control Keywords",
      "entries": [
        {
          "syntax": "break",
          "example": "if done: break",
          "description": "Terminates loop"
        },
        {
          "syntax": "continue",
          "example": "if skip: continue",
          "description": "Jumps to next iteration"
        },
        {
          "syntax": "pass",
          "example": "class Empty: pass",
          "description": "No-operation placeholder"
        }
