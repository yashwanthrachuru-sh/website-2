{
  "printNote": "Python Strings & Booleans Cheat Sheet",
  "sections": [
    {
      "heading": "String Operations",
      "entries": [
        {
          "syntax": "s.strip()",
          "example": "' hi '.strip() -> 'hi'",
          "description": "Removes leading/trailing whitespace"
        },
        {
          "syntax": "s.split(delim)",
          "example": "'a,b,c'.split(',') -> ['a','b','c']",
          "description": "Splits string into list"
        },
        {
          "syntax": "delim.join(list)",
          "example": "'-'.join(['a','b']) -> 'a-b'",
          "description": "Joins list elements into string"
        }
      ]
    }
  ]
}